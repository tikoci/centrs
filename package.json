{
	"name": "centrs",
	"version": "0.1.0",
	"main": "src/index.ts",
	"module": "src/index.ts",
	"devDependencies": {
		"@agent-lint/cli": "^0.8.1",
		"@biomejs/biome": "2.4.13",
		"@secretlint/secretlint-rule-preset-recommend": "^12.3.1",
		"@tikoci/quickchr": "^0.2.0",
		"@types/bun": "^1.3.13",
		"cloc": "^2.6.0-cloc",
		"cspell": "^10.0.0",
		"has-flag": "4.0.0",
		"markdownlint-cli2": "^0.22.1",
		"secretlint": "^12.3.1",
		"typedoc": "^0.28.19"
	},
	"optionalDependencies": {},
	"peerDependencies": {
		"typescript": "^6.0.3"
	},
	"exports": {
		".": "./src/index.ts",
		"./cli": "./src/cli.ts",
		"./mcp": "./src/mcp.ts",
		"./tui": "./src/tui.ts",
		"./webproxy": "./src/webproxy.ts",
		"./protocols": "./src/protocols/index.ts"
	},
	"bin": {
		"centrs": "src/cli.ts"
	},
	"description": "All-in-one TypeScript library/CLI/TUI/MCP for interacting with MikroTik RouterOS devices",
	"engines": {
		"bun": ">=1.3.0"
	},
	"private": false,
	"scripts": {
		"ci": "bun run lint && bun run test && bun run build",
		"git:pre-commit": "bun run lint",
		"git:pre-push": "bun run ci",
		"lint": "bun run lint:biome && bun run lint:typecheck",
		"lint:git:commit": "bun run lint",
		"lint:git:push": "bun run ci",
		"lint:ci": "bun run lint && bun run lint:markdownlint && bun run lint:cspell && bun run lint:secretlint && bun run lint:agents",
		"lint:cspell": "cspell lint .",
		"lint:markdownlint": "markdownlint-cli2 \"**/*.md\"",
		"lint:markdownlint:fix": "markdownlint-cli2 --fix \"**/*.md\"",
		"lint:typecheck": "tsc --noEmit",
		"lint:biome": "biome check .",
		"lint:fix": "biome check --write .",
		"lint:secretlint": "secretlint \"**/*\"",
		"lint:agents": "agent-lint scan --stdout",
		"test": "bun test",
		"test:ci": "bun test --coverage",
		"test:all": "bun run test:ci",
		"build": "bun build src/index.ts src/cli.ts src/mcp.ts src/tui.ts src/webproxy.ts src/protocols/index.ts --outdir dist --target bun",
		"build:doc:api": "typedoc --out docs/api src/index.ts",
		"security": "bun run lint:secretlint && bun run lint:markdownlint"
	},
	"type": "module",
	"types": "src/index.ts"
}
