# centrs environment variables
# See docs/specs/S004-cli-settings-and-precedence.md for the full vocabulary.
# These names are planned; the CLI does not consume them yet.

# Default target device or group label
CENTRS_DEVICE=
CENTRS_GROUP=

# Direct target coordinates (override registry lookup)
CENTRS_HOST=
CENTRS_ADDRESS=
CENTRS_MAC=

# Requested protocol adapter: rest-api | native-api | ssh | snmp | mndp | mac-telnet | romon | winbox-terminal
CENTRS_VIA=

# Credentials (prefer Keychain or other secret store once implemented)
CENTRS_USERNAME=
CENTRS_PASSWORD=

# Validation policy: explain | validate | run (run implies validate)
CENTRS_VALIDATE=validate

# Whether resolved metadata should be persisted to the SQLite cache
CENTRS_CACHE=false

# Output format: text | json | table
CENTRS_FORMAT=text
