{
	"version": "0.2",
	"language": "en",
	"enabled": true,
	"enableGlobDot": true,
	"ignorePaths": [
		"node_modules",
		".git",
		"cspell.json",
		"coverage",
		"dist",
		"docs/api",
		"test/fixtures",
		"GLOSSARY.txt"
	],
	"useGitignore": false,
	"flagWords": ["hte"],
	"ignoreWords": ["behaviour"],
	"words": [],
	"maxNumberOfProblems": 100,
	"numSuggestions": 8,
	"minWordLength": 3,
	"enabledLanguageIds": ["*"],
	"allowCompoundWords": false,
	"dictionaryDefinitions": [
		{
			"name": "project-words",
			"path": "./GLOSSARY.txt",
			"addWords": true
		}
	],
	"dictionaries": ["project-words"]
}
